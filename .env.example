# Solana RPC (public — safe in client)
NEXT_PUBLIC_SOLANA_RPC=https://api.mainnet-beta.solana.com

# $Gotchi SPL token mint address (public)
NEXT_PUBLIC_GOTCHI_MINT=CvMRRYAf7wvs3qrvRU9mcLhwK6RAbftxoiejDR1xpump

# Treasury wallet public address (optional display override; otherwise derived from private key)
NEXT_PUBLIC_TREASURY_WALLET=

# Treasury signer — NEVER commit this. Put only in .env.local
# Base58 secret key OR JSON byte array from Phantom export
TREASURY_PRIVATE_KEY=

# Token decimals for $Gotchi (pump.fun tokens are usually 6)
GOTCHI_TOKEN_DECIMALS=6

# Secret required to call POST /api/treasury/payout (admin manual payouts)
TREASURY_ADMIN_SECRET=

# Pay 1 token per milestone claim instead of full tier amount (for testing)
CLAIM_TEST_MODE=false

# Optional: external claim API when frontend is static (GitHub Pages)
# NEXT_PUBLIC_CLAIM_API_URL=https://your-render-app.onrender.com

# Live chat on GitHub Pages (free Supabase project — run supabase/live-chat.sql)
# NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# --- Devnet test setup (copy to .env.local for dry runs) ---
# NEXT_PUBLIC_SOLANA_RPC=https://api.devnet.solana.com
# NEXT_PUBLIC_GOTCHI_MINT=<your-devnet-test-mint>
# TREASURY_PRIVATE_KEY=<devnet-treasury-secret>
# CLAIM_TEST_MODE=true
